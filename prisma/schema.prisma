generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique // nullable: OAuth-only users may not have picked one yet
  emailVerified DateTime? @map("email_verified")
  passwordHash  String?   @map("password_hash") // nullable: OAuth-only users have no password
  displayName   String?   @map("display_name") // nullable: the username is the display fallback
  bio           String?
  avatarKey     String?   @map("avatar_key") // MinIO object key
  image         String? // adapter convention: avatar URL from OAuth profile
  isPrivate     Boolean   @default(false) @map("is_private")
  isAdmin       Boolean   @default(false) @map("is_admin") // grants access to the admin insights dashboard
  inviteCode    String?   @unique @map("invite_code") // personal invite-link code, generated on first share
  invitedById   String?   @map("invited_by_id") // who invited this user, set once at registration
  createdAt     DateTime  @default(now()) @map("created_at")

  notifyLikes    Boolean @default(true) @map("notify_likes")
  notifyComments Boolean @default(true) @map("notify_comments")
  notifyFollows  Boolean @default(true) @map("notify_follows")
  notifyMentions Boolean @default(true) @map("notify_mentions")

  locale String? // preferred UI language (e.g. "en", "de"); null = auto-detect

  invitedBy User?  @relation("Invitations", fields: [invitedById], references: [id], onDelete: SetNull)
  invitees  User[] @relation("Invitations")

  accounts          Account[]
  catEntries        CatEntry[]
  cats              Cat[]
  following         Follow[]           @relation("Follower")
  followers         Follow[]           @relation("Followee")
  likes             Like[]
  comments          Comment[]
  notifications     Notification[]     @relation("NotificationsReceived")
  sentNotifications Notification[]     @relation("NotificationsSent")
  pushSubscriptions PushSubscription[]
  entryViews        EntryView[]
  catLinkRequests   CatLink[]          @relation("CatLinkRequester")

  @@map("users")
}

// Auth.js (next-auth) adapter models. `Session` is intentionally omitted:
// sessions use the JWT strategy, not database-backed sessions, so only
// `Account` (OAuth identity linking) and `VerificationToken` are needed.
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// The journal artifact an entry's photos are presented as. Purely a render
// choice (the polaroid stack, a pressed-specimen card, an index card, …) —
// it never gates documenting, so it always has a sensible default.
enum FrameStyle {
  POLAROID
  SPECIMEN
  INDEX_CARD
  POSTCARD
  TICKET

  @@map("frame_style")
}

model CatEntry {
  id           String     @id @default(cuid())
  ownerId      String     @map("owner_id")
  owner        User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  catId        String?    @map("cat_id") // optional link to a persistent Cat profile this sighting is of
  cat          Cat?       @relation(fields: [catId], references: [id], onDelete: SetNull)
  name         String?
  breed        String?
  notes        String?
  locationName String?    @map("location_name") // human-readable place name shown in the UI
  latitude     Float? // null when the user disabled geo data for this entry
  longitude    Float?
  frameStyle   FrameStyle @default(POLAROID) @map("frame_style")
  frameColor   String?    @map("frame_color") // optional chrome-color preset key; null = the frame's default palette
  frameTilt    Int?       @map("frame_tilt") // optional hand-set tilt in degrees; null = the auto, id-hashed tilt
  frameCaption String?    @map("frame_caption") // optional custom text for the frame's label field (call no. / ticket line / greeting)
  createdAt    DateTime   @default(now()) @map("created_at")

  embedding Unsupported("vector(512)")?

  photos        CatEntryPhoto[]
  likes         Like[]
  comments      Comment[]
  notifications Notification[]
  views         EntryView[]
  catLinks      CatLink[]

  @@index([ownerId, createdAt])
  @@index([catId])
  @@map("cat_entries")
}

// A persistent cat profile — a named cat that one or more sightings
// (`CatEntry`) point at, building a timeline of that single cat over time
// ("Mochi, across the months"). `isOwned` distinguishes *my cats* (claimed,
// cats the user keeps) from *cats I've met* (street cats I document); both are
// collectible, only the former is "claimed". A cat belongs to the user who
// created it and its visibility follows that owner's profile visibility (the
// same rule as their entries). The cat's photo is drawn from its linked
// entries — there is no separate cat avatar upload. This is the structural
// backbone for per-cat metadata, re-identification and welfare flags later
// (see docs/feature-ideas.md); kept deliberately lean for now.
model Cat {
  id          String   @id @default(cuid())
  ownerId     String   @map("owner_id")
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  breed       String?
  color       String?
  description String?
  isOwned     Boolean  @default(false) @map("is_owned")
  createdAt   DateTime @default(now()) @map("created_at")

  entries       CatEntry[]
  links         CatLink[]
  notifications Notification[]

  @@index([ownerId, createdAt])
  @@map("cats")
}

// A re-identification claim: a proposal that one user's sighting (`catEntry`) is
// the same animal as another user's `Cat`. This is the cross-person bridge for
// "might this be cat X?" — when the cat belongs to someone else, the sighting
// owner files a request and the cat's owner approves or declines. On approval
// the sighting's `catId` is repointed at the cat, so a single cat's timeline can
// gather sightings from many people (iNaturalist-style). Same-owner links skip
// this entirely (they're set directly and no row is created).
enum CatLinkStatus {
  PENDING
  APPROVED
  DECLINED

  @@map("cat_link_status")
}

model CatLink {
  id          String        @id @default(cuid())
  catId       String        @map("cat_id") // the target cat (owned by the approver)
  catEntryId  String        @map("cat_entry_id") // the sighting being linked (owned by the requester)
  requesterId String        @map("requester_id") // who proposed the link (the sighting's owner)
  status      CatLinkStatus @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")

  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  catEntry  CatEntry @relation(fields: [catEntryId], references: [id], onDelete: Cascade)
  requester User     @relation("CatLinkRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([catId, catEntryId])
  @@index([catId, status])
  @@index([requesterId])
  @@map("cat_links")
}

// A logged-in viewer's "seen" record for an entry — the audience side of the
// engagement picture (likes/comments are the active interactions). One row per
// (user, entry), deduped: `firstSeenAt` is the first view, `lastSeenAt`/`count`
// track repeat visits. The entry owner's own views are never recorded, so
// insights measure the audience rather than the author.
model EntryView {
  userId          String   @map("user_id")
  catEntryId      String   @map("cat_entry_id")
  count           Int      @default(1) // detail-page opens ("seen")
  feedImpressions Int      @default(0) @map("feed_impressions") // times the card scrolled into view in a list/feed
  dwellMs         Int      @default(0) @map("dwell_ms") // cumulative ms the entry was on-screen (feed + detail)
  maxReadPct      Int      @default(0) @map("max_read_pct") // furthest scroll depth reached on the detail page (0–100)
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  catEntry CatEntry @relation(fields: [catEntryId], references: [id], onDelete: Cascade)

  @@id([userId, catEntryId])
  @@index([catEntryId])
  @@index([userId, lastSeenAt])
  @@map("entry_views")
}

// One photo of an entry (up to MAX_PHOTOS_PER_ENTRY, ordered by position;
// position 0 is the cover used for thumbnails, OG images and embeddings).
model CatEntryPhoto {
  id         String  @id @default(cuid())
  catEntryId String  @map("cat_entry_id")
  photoKey   String  @map("photo_key") // MinIO object key (original)
  thumbKey   String? @map("thumb_key") // MinIO object key (sharp-generated thumbnail)
  position   Int     @default(0)

  catEntry CatEntry @relation(fields: [catEntryId], references: [id], onDelete: Cascade)

  @@index([catEntryId, position])
  @@map("cat_entry_photos")
}

model Follow {
  followerId String   @map("follower_id")
  followeeId String   @map("followee_id")
  approved   Boolean  @default(true) // false while pending, for private profiles
  createdAt  DateTime @default(now()) @map("created_at")

  follower User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
  @@map("follows")
}

// The themed observational stamp a reader leaves on an entry. PAW is the plain
// "I saw this" paw; the others are field-journal flavoured (spotted!, handsome
// devil, be safe). SAME_CAT is special — it's a re-identification *data signal*
// ("I think I've met this cat"), not applause. One reaction per (user, entry):
// picking a different stamp replaces the previous one.
enum ReactionKind {
  PAW
  SPOTTED
  HANDSOME
  SAME_CAT
  SAFE

  @@map("reaction_kind")
}

// A reader's reaction to an entry (table is still `likes` for history's sake).
// `kind` defaults to PAW so every pre-reactions row reads as a plain paw.
model Like {
  userId     String       @map("user_id")
  catEntryId String       @map("cat_entry_id")
  kind       ReactionKind @default(PAW)
  createdAt  DateTime     @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  catEntry CatEntry @relation(fields: [catEntryId], references: [id], onDelete: Cascade)

  @@id([userId, catEntryId])
  @@map("likes")
}

model Comment {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  catEntryId String   @map("cat_entry_id")
  parentId   String?  @map("parent_id") // null = top-level note; set = reply within that note's thread
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  catEntry      CatEntry       @relation(fields: [catEntryId], references: [id], onDelete: Cascade)
  parent        Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("CommentReplies")
  notifications Notification[]

  @@index([catEntryId, createdAt])
  @@index([parentId])
  @@map("comments")
}

enum NotificationType {
  LIKE
  COMMENT
  REPLY
  FOLLOW
  MENTION
  CAT_LINK_REQUEST // someone thinks their sighting is your cat — awaiting your approval
  CAT_LINK_APPROVED // the cat's owner accepted your "same cat?" link

  @@map("notification_type")
}

model Notification {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  actorId    String           @map("actor_id")
  type       NotificationType
  catEntryId String?          @map("cat_entry_id")
  commentId  String?          @map("comment_id")
  catId      String?          @map("cat_id") // target cat for re-identification (CAT_LINK_*) notifications
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now()) @map("created_at")

  user     User      @relation("NotificationsReceived", fields: [userId], references: [id], onDelete: Cascade)
  actor    User      @relation("NotificationsSent", fields: [actorId], references: [id], onDelete: Cascade)
  catEntry CatEntry? @relation(fields: [catEntryId], references: [id], onDelete: Cascade)
  comment  Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  cat      Cat?      @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
