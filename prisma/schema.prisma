generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique // nullable: OAuth-only users may not have picked one yet
  emailVerified DateTime?
  passwordHash  String? // nullable: OAuth-only users have no password
  displayName   String? // nullable: the username is the display fallback
  bio           String?
  avatarKey     String? // MinIO object key
  image         String? // adapter convention: avatar URL from OAuth profile
  isPrivate     Boolean   @default(false)
  isAdmin       Boolean   @default(false) // grants access to the admin insights dashboard
  inviteCode    String?   @unique // personal invite-link code, generated on first share
  invitedById   String? // who invited this user, set once at registration
  createdAt     DateTime  @default(now())

  notifyLikes    Boolean @default(true)
  notifyComments Boolean @default(true)
  notifyFollows  Boolean @default(true)
  notifyMentions Boolean @default(true)

  locale String? // preferred UI language (e.g. "en", "de"); null = auto-detect

  invitedBy User?  @relation("Invitations", fields: [invitedById], references: [id], onDelete: SetNull)
  invitees  User[] @relation("Invitations")

  accounts          Account[]
  catEntries        CatEntry[]
  following         Follow[]         @relation("Follower")
  followers         Follow[]         @relation("Followee")
  likes             Like[]
  comments          Comment[]
  notifications     Notification[]   @relation("NotificationsReceived")
  sentNotifications Notification[]   @relation("NotificationsSent")
  pushSubscriptions PushSubscription[]
  entryViews        EntryView[]
}

// Auth.js (next-auth) adapter models. `Session` is intentionally omitted:
// sessions use the JWT strategy, not database-backed sessions, so only
// `Account` (OAuth identity linking) and `VerificationToken` are needed.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// The journal artifact an entry's photos are presented as. Purely a render
// choice (the polaroid stack, a pressed-specimen card, an index card, …) —
// it never gates documenting, so it always has a sensible default.
enum FrameStyle {
  POLAROID
  SPECIMEN
  INDEX_CARD
  POSTCARD
  TICKET
}

model CatEntry {
  id           String     @id @default(cuid())
  ownerId      String
  owner        User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String?
  breed        String?
  notes        String?
  locationName String? // human-readable place name shown in the UI
  latitude     Float? // null when the user disabled geo data for this entry
  longitude    Float?
  frameStyle   FrameStyle @default(POLAROID)
  createdAt    DateTime   @default(now())

  embedding Unsupported("vector(512)")?

  photos        CatEntryPhoto[]
  likes         Like[]
  comments      Comment[]
  notifications Notification[]
  views         EntryView[]

  @@index([ownerId, createdAt])
}

// A logged-in viewer's "seen" record for an entry — the audience side of the
// engagement picture (likes/comments are the active interactions). One row per
// (user, entry), deduped: `firstSeenAt` is the first view, `lastSeenAt`/`count`
// track repeat visits. The entry owner's own views are never recorded, so
// insights measure the audience rather than the author.
model EntryView {
  userId      String
  catEntryId  String
  count       Int      @default(1)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  catEntry CatEntry @relation(fields: [catEntryId], references: [id], onDelete: Cascade)

  @@id([userId, catEntryId])
  @@index([catEntryId])
  @@index([userId, lastSeenAt])
}

// One photo of an entry (up to MAX_PHOTOS_PER_ENTRY, ordered by position;
// position 0 is the cover used for thumbnails, OG images and embeddings).
model CatEntryPhoto {
  id         String  @id @default(cuid())
  catEntryId String
  photoKey   String // MinIO object key (original)
  thumbKey   String? // MinIO object key (sharp-generated thumbnail)
  position   Int     @default(0)

  catEntry CatEntry @relation(fields: [catEntryId], references: [id], onDelete: Cascade)

  @@index([catEntryId, position])
}

model Follow {
  followerId String
  followeeId String
  approved   Boolean  @default(true) // false while pending, for private profiles
  createdAt  DateTime @default(now())

  follower User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
}

model Like {
  userId     String
  catEntryId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  catEntry CatEntry @relation(fields: [catEntryId], references: [id], onDelete: Cascade)

  @@id([userId, catEntryId])
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  catEntryId String
  parentId   String? // null = top-level note; set = reply within that note's thread
  body       String
  createdAt  DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  catEntry      CatEntry       @relation(fields: [catEntryId], references: [id], onDelete: Cascade)
  parent        Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("CommentReplies")
  notifications Notification[]

  @@index([catEntryId, createdAt])
  @@index([parentId])
}

enum NotificationType {
  LIKE
  COMMENT
  REPLY
  FOLLOW
  MENTION
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  actorId    String
  type       NotificationType
  catEntryId String?
  commentId  String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user     User      @relation("NotificationsReceived", fields: [userId], references: [id], onDelete: Cascade)
  actor    User      @relation("NotificationsSent", fields: [actorId], references: [id], onDelete: Cascade)
  catEntry CatEntry? @relation(fields: [catEntryId], references: [id], onDelete: Cascade)
  comment  Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
