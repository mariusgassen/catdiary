# Copy this file to .env and fill in real values for local development.
# In Coolify, enter these as the resource's environment variables/secrets.

# --- Database (Postgres) ---
POSTGRES_USER=catdiary
POSTGRES_PASSWORD=changeme
POSTGRES_DB=catdiary
DATABASE_URL=postgresql://catdiary:changeme@db:5432/catdiary

# --- Auth.js (next-auth v5) ---
# Generate with `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- Social login (all optional — each provider only "lights up" once both
# of its variables below are set; until then the app runs on email/password
# alone). Register OAuth apps with each provider's developer console. ---

# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook Login: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple Sign In: https://developer.apple.com (requires a paid Apple Developer
# account). NOTE: Apple does not issue a static client secret — APPLE_SECRET
# must be a JWT you mint yourself, signed with ES256 using a private key
# (.p8) downloaded from your Apple Developer account, with claims:
#   iss = Team ID, sub = APPLE_ID (Services ID), aud = "https://appleid.apple.com"
# and an expiry of at most 6 months. Treat this as a scripted/manual step,
# not a value you can copy-paste once. See https://authjs.dev/getting-started/providers/apple
APPLE_ID=
APPLE_SECRET=

# --- MinIO / S3-compatible object storage ---
MINIO_ROOT_USER=catdiary
MINIO_ROOT_PASSWORD=changeme-too
# Internal (server-side, container-to-container) endpoint:
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=catdiary
MINIO_SECRET_KEY=changeme-too
MINIO_BUCKET=cat-diary-photos

# --- Public base URL ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
